{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/app/**/{page,layout,loading,error,not-found,route,template,default}.{ts,tsx}",
    "**/*.test.{ts,tsx}"
  ],
  "project": ["src/**/*.{ts,tsx}"],
  "ignoreDependencies": [
    "@stryker-mutator/core",
    "@stryker-mutator/vitest-runner",
    "eslint-config-next",
    "tailwindcss",
    "sober"
  ],
  "ignoreBinaries": ["sober"]
}
